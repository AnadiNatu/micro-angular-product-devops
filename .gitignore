# ============================================================
# .gitignore additions for microservice-demo project root
# Add these lines to your existing .gitignore
# ============================================================

# ─── Secret environment files — NEVER COMMIT ─────────────────
.env
.env.prod
.env.local
*.env.local
!.env.example

# ─── Spring Boot build artifacts ─────────────────────────────
*/target/
**/target/
!**/target/

# ─── Upload folders ───────────────────────────────────────────
uploads/
user-profile-photos/
**/uploads/

# ─── Docker ────────────────────────────────────────────────────
.docker/

# ─── Node / Angular ────────────────────────────────────────────
node_modules/
dist/
.angular/cache
npm-debug.log*

# ─── IDE ───────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.suo
.DS_Store
Thumbs.db

# ─── Logs ──────────────────────────────────────────────────────
logs/
*.log
