# ============================================================
# .env.example  ✅ COMMIT THIS — placeholder values only
# cp .env.example .env  then fill in real values
# ============================================================

# ─── PostgreSQL superuser ──────────────────────────────────────
POSTGRES_USER=your_pg_superuser
POSTGRES_PASSWORD=your_strong_pg_password

# ─── Auth Service DB ──────────────────────────────────────────
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=your_auth_db_password

# ─── Demo Service 1 DB ────────────────────────────────────────
DEMO1_DB_NAME=demo1_db
DEMO1_DB_USER=demo1_user
DEMO1_DB_PASSWORD=your_demo1_db_password

# ─── Demo Service 2 DB ────────────────────────────────────────
DEMO2_DB_NAME=demo2_db
DEMO2_DB_USER=demo2_user
DEMO2_DB_PASSWORD=your_demo2_db_password

# ─── JWT (min 64 chars for HS512) ─────────────────────────────
JWT_SECRET=your_jwt_secret_at_least_64_characters_long_replace_this_now_xxxx

# ─── Mail ─────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ─── Twilio ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── OAuth2 ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── Frontend URL ─────────────────────────────────────────────
FRONTEND_URL=http://localhost

# ─── Spring Profile ───────────────────────────────────────────
SPRING_PROFILES_ACTIVE=docker

# ─── AWS (leave blank locally — EC2 uses IAM role) ───────────
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=