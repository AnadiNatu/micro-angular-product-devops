# =============================================================================
# .env.example — copy to .env for local Docker, .env.prod for EC2
# NEVER commit .env or .env.prod — add both to .gitignore
# =============================================================================

# ── Compose profile ───────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=docker

# ── PostgreSQL (local Docker only — RDS replaces this in prod) ────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# Auth Service DB
AUTH_DB_NAME=AuthServiceDB
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=change_me

# Demo Service 1 DB
DEMO1_DB_NAME=DemoService1DB
DEMO1_DB_USER=demo1_user
DEMO1_DB_PASSWORD=change_me

# Demo Service 2 DB
DEMO2_DB_NAME=DemoService2DB
DEMO2_DB_USER=demo2_user
DEMO2_DB_PASSWORD=change_me

# ── JWT ───────────────────────────────────────────────────────────
# Must be >= 64 characters for HS512
JWT_SECRET=YourSecretKeyHereMustBeLongEnoughForHS512AlgorithmAtLeast64Characters123456

# ── Mail (Gmail SMTP) ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ── Twilio ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Cloudinary ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── OAuth2 ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Frontend URL ──────────────────────────────────────────────────
# Local Docker: http://localhost  |  Prod: https://yourdomain.com
FRONTEND_URL=http://localhost

# ── AWS (prod only — leave blank for local) ───────────────────────
# In prod .env.prod, set POSTGRES_HOST to RDS endpoint:
#   POSTGRES_HOST=mydb.xxxx.us-east-1.rds.amazonaws.com
#   POSTGRES_PORT=5432
POSTGRES_HOST=
POSTGRES_PORT=5432
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name
